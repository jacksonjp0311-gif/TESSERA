{
  "schema": "TESSERA-PRODUCTION-CONFIG-v0.2",
  "runtime": {
    "execution_model": "host-supervised-local-subprocess",
    "timeout_ms": 5000,
    "worker_cpu_threads": 1,
    "max_consecutive_failures": 3,
    "max_events": 512,
    "max_feature_count": 32,
    "max_metadata_count": 16,
    "warmup_required": true,
    "inline_neural_training": false
  },
  "session_adapter": {
    "schema": "TESSERA-SESSION-SUMMARY-v0.1",
    "aggregation": [
      "mean",
      "std",
      "latest"
    ],
    "completion_rule": "emit exactly one summary event after host session completion",
    "ordering_rule": "preserve completed-session chronology",
    "sensitive_payloads_allowed": false
  },
  "authority": {
    "host_memory_write": false,
    "tool_invocation": false,
    "prompt_mutation": false,
    "live_codec_replacement": false,
    "topology_mutation": false,
    "external_api_calls": false
  },
  "release_gate": {
    "command": "python -m tessera launch-readiness --root .",
    "certification_order": [
      "production-candidate",
      "local-security-readiness",
      "release-readiness"
    ],
    "parallel_execution_allowed": false,
    "warm_p95_budget_ms": 250,
    "soak_p99_budget_ms": 250,
    "route_parity_required": 1.0,
    "restart_determinism_required": true,
    "rollback_required": true,
    "failure_isolation_required": true
  },
  "host_integration_gate": {
    "command": "python -m tessera host-integration-readiness --root . --hermes-root <path-to-hermes-agent>",
    "reference_integrations": [
      "agent-cli-mirror",
      "hermes-agent"
    ],
    "independent_production_trials_required": true
  },
  "semantic_observability_gate": {
    "effective_feature_selection": "range_j > 1e-6 * max(max_abs_j, 1)",
    "minimum_coverage": 1.0,
    "insufficient_coverage_route": "abstain",
    "insufficient_coverage_memory_candidate": false
  },
  "manifold_drift_gate": {
    "support_rule": "observed effective indices must exactly match calibration",
    "intrinsic_rank_energy": 0.98,
    "maximum_principal_angle_degrees": 10.0,
    "maximum_robust_center_shift": 2.0,
    "accepted_principal_scale_ratio": [
      0.2,
      3.0
    ],
    "drift_route": "abstain",
    "drift_memory_candidate": false
  },
  "sequential_geometry_gate": {
    "signal": "absolute robust-normalized residual orthogonal to the calibrated filament",
    "reference_allowance": 0.75,
    "evidence_clip": 3.0,
    "alarm_threshold": 5.0,
    "alarm_latched_until_validated_reset": true,
    "alarm_route": "abstain",
    "alarm_memory_candidate": false
  },
  "prefix_state_cache": {
    "identity_rule": "incoming normalized history must exactly equal cached prefix",
    "cached_state": [
      "field",
      "level",
      "previous_code",
      "last_observation",
      "historical_metric_rows"
    ],
    "prefix_mismatch_behavior": "full_replay",
    "approximate_cache_hits_allowed": false
  },
  "claim_boundary": "This configuration defines a local candidate profile. External launch blockers remain authoritative."
}
