{
  "schema": "TESSERA-runtime-loop-compiler-v0.2.2",
  "loop": [
    {
      "order": "01",
      "stage": "REHYDRATE",
      "purpose": "load README, AGENTS, route map, origin manifest, metrics, claim locks"
    },
    {
      "order": "02",
      "stage": "SHELL",
      "purpose": "enter compressed PowerShell operator surface"
    },
    {
      "order": "03",
      "stage": "COMPILE",
      "purpose": "render ASCII, Bash, PowerShell, manifest, and README dropdowns"
    },
    {
      "order": "04",
      "stage": "CHECK",
      "purpose": "run RCC, architecture, README, operator shell, loop, and unit checkers"
    },
    {
      "order": "05",
      "stage": "RUN",
      "purpose": "execute local Tessera runtime without pip reinstall"
    },
    {
      "order": "06",
      "stage": "VALIDATE",
      "purpose": "validate latest evidence, certificate, wounds, metrics, and claim ceiling"
    },
    {
      "order": "07",
      "stage": "LEDGER",
      "purpose": "write reports/runtime_loop and lessons learned"
    },
    {
      "order": "08",
      "stage": "PUSH",
      "purpose": "commit and push after local evidence passes"
    },
    {
      "order": "09",
      "stage": "ROOT",
      "purpose": "return to repository root"
    }
  ],
  "operator_shell": "scripts/tessera-shell.ps1",
  "commands": [
    "status",
    "compile",
    "check",
    "run",
    "validate",
    "full",
    "push",
    "help",
    "exit"
  ],
  "outputs": {
    "ascii": "reports/runtime_loop/tessera_loop_ascii.txt",
    "manifest": "reports/runtime_loop/tessera_loop_manifest.json",
    "readme_section": "reports/runtime_loop/tessera_readme_operator_shell_section.md",
    "lessons": "reports/lessons/tessera_v0_2_2_operator_shell_lessons.md"
  },
  "claim_boundary": "Operator shell improves local visibility and repeatability. It does not prove correctness, safety, production readiness, or real telemetry transfer."
}