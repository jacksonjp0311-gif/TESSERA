        {
          "phase": "MIRROR",
          "label": "agent mirror validate",
          "cmd": [
            "{python}",
            "agent_cli_mirror/agent_mirror.py",
            "validate",
            "--root",
            "{root}"
          ]
        },
        {
          "phase": "REGISTRY",
          "label": "show commands",
          "cmd": [
            "{python}",
            "agent_cli_mirror/agent_mirror.py",
            "commands",
            "--root",
            "{root}"
          ]
        }
      ]
    },
